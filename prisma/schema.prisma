generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        String   // hospital, pharmacy, vendor, distributor
  accountType String   // buyer, seller
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  products    Product[]
  buyerOrders Order[]  @relation("BuyerOrgOrders")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  orgId        String
  accountType  String   // buyer, seller
  role         String   // approver, requestor
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id])
  orders Order[]
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String   // syringes, gloves, cotton, bandages, surgical_masks, iv_sets, gauze, catheters, ppe_kits, disposable_drapes, alcohol_swabs, specimen_containers, surgical_tape, cannulas, urine_bags, disposable_gowns, face_shields, shoe_covers, hand_sanitizers, disposable_caps
  imageUrl        String?
  stock           Int      @default(100)
  unit            String   @default("box")
  tierPricing     String   // JSON string: [{ minQty, unitPrice }]
  sterility       String   // sterile, non_sterile
  disposable      Boolean  @default(true)
  packagingQty    Int      @default(1)
  manufacturer    String?
  qualityMetadata String?  // JSON string: { material, plasticGrade, certifications[] }
  discountPercent     Float?   // Discount percentage (e.g. 5 for 5%)
  minOrderForDiscount Int?     // Minimum order quantity to qualify for discount
  sellerOrgId     String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sellerOrg Organization @relation(fields: [sellerOrgId], references: [id])
}

model Order {
  id              String   @id @default(cuid())
  buyerOrgId      String
  createdById     String
  status          String   // draft, pending_approval, approved, paid, delivered, rejected
  items           String   // JSON string: [{ product, productName, sellerOrg, quantity, unitPrice, lineTotal }]
  total           Float
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  buyerOrg Organization @relation("BuyerOrgOrders", fields: [buyerOrgId], references: [id])
  creator  User         @relation(fields: [createdById], references: [id])
}
