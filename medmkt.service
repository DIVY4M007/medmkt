[Unit]
Description=MedMkt Healthcare B2B Marketplace
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/medmkt
ExecStart=/bin/bash -c 'npx next start -p 3000 -H 0.0.0.0'
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production
Environment=DATABASE_URL=file:./db/production.db
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
